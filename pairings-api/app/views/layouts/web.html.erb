<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <title>Pairings</title>
</head>
<body class="h-full pb-16 sm:pb-0" style="background: var(--bg-page); color: var(--text-primary);">
  <%= render "web/shared/navbar" %>

  <main class="mx-auto max-w-lg px-4 py-6 pb-20 sm:max-w-2xl sm:pb-6 lg:max-w-4xl">
    <%= render "web/shared/flash" %>
    <%= yield %>
  </main>
</body>
</html>
