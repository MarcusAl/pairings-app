<div class="flex min-h-[80vh] items-center justify-center">
  <div class="w-full max-w-sm space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold"><%= t(".title") %></h1>
      <p class="mt-1 text-sm text-gray-500"><%= t(".subtitle") %></p>
    </div>

    <%= form_with url: web_login_path, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email",
            class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password, required: true, autocomplete: "current-password",
            class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <%= f.submit t(".sign_in"), class: "w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 cursor-pointer" %>
    <% end %>

    <div class="relative">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
      <div class="relative flex justify-center text-sm"><span class="bg-gray-50 px-2 text-gray-500"><%= t(".or") %></span></div>
    </div>

    <%= button_to t(".continue_with_auth0"), "/auth/auth0", method: :post, data: { turbo: false },
        class: "w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer" %>

    <p class="text-center text-sm text-gray-500">
      <%= t(".no_account_html", link: link_to(t(".sign_up"), web_signup_path, class: "font-medium text-indigo-600 hover:text-indigo-500")) %>
    </p>
  </div>
</div>
