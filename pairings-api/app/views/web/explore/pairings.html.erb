<div class="space-y-6">
  <h1 class="heading-page"><%= t(".title") %></h1>

  <% if @pairings.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% @pairings.each do |pairing| %>
        <%= render "web/shared/pairing_card", pairing: pairing, path: web_explore_pairings_path %>
      <% end %>
    </div>

    <%= render "web/shared/pagination" %>
  <% else %>
    <p class="empty-state"><%= t(".no_pairings") %></p>
  <% end %>
</div>
