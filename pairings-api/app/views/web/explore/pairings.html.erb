<div class="space-y-6">
  <h1 class="heading-page"><%= t(".title") %></h1>

  <% if @pairings.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% @pairings.each do |pairing| %>
        <%= render "web/shared/pairing_card", pairing: pairing, path: web_explore_pairings_path %>
      <% end %>
    </div>

    <%= render "web/shared/pagination" %>
  <% else %>
    <div class="empty-state">
      <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" style="color: var(--border-subtle);" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
      <p><%= t(".no_pairings") %></p>
    </div>
  <% end %>
</div>
