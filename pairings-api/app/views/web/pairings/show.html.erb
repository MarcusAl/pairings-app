<div class="space-y-6">
  <div class="flex items-center justify-between">
    <%= link_to web_pairings_path, class: "back-link" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <%= t(".back") %>
    <% end %>
    <%= button_to t(".delete"), web_pairing_path(@pairing), method: :delete,
        data: { turbo_confirm: t(".delete_confirm") },
        class: "btn btn--danger btn--sm" %>
  </div>

  <div class="card">
    <div class="flex">
      <% [@pairing.item1, @pairing.item2].each do |item| %>
        <%= link_to web_item_path(item), class: "w-1/2 group" do %>
          <div class="aspect-square overflow-hidden" style="background: var(--border-card);">
            <% if item.image.attached? %>
              <%= image_tag item.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: item.name %>
            <% end %>
          </div>
          <div class="p-3 text-center">
            <p class="text-sm font-semibold truncate" style="color: var(--text-primary);"><%= item.name %></p>
            <span class="text-detail"><%= Item::CATEGORIES[item.category] %></span>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="p-4 sm:p-6 space-y-4 border-t divider">
      <% if @pairing.strength %>
        <div class="flex items-center gap-3">
          <span class="text-sm font-medium" style="color: var(--text-primary);"><%= t(".strength") %></span>
          <div class="flex gap-1">
            <% 5.times do |i| %>
              <div class="w-8 h-2 strength-bar <%= 'strength-bar--filled' if i < @pairing.strength %>"></div>
            <% end %>
          </div>
          <span class="text-detail"><%= @pairing.strength %>/5</span>
        </div>
      <% end %>

      <% if @pairing.confidence_score %>
        <div class="flex items-center gap-3">
          <span class="text-sm font-medium" style="color: var(--text-primary);"><%= t(".confidence") %></span>
          <span class="text-detail"><%= number_to_percentage(@pairing.confidence_score * 100, precision: 0) %></span>
        </div>
      <% end %>

      <% if @pairing.ai_reasoning.present? %>
        <div>
          <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);"><%= t(".ai_reasoning") %></h3>
          <p class="text-body"><%= @pairing.ai_reasoning %></p>
        </div>
      <% end %>

      <% if @pairing.pairing_notes.present? %>
        <div>
          <h3 class="text-sm font-medium mb-1" style="color: var(--text-primary);"><%= t(".notes") %></h3>
          <p class="text-body"><%= @pairing.pairing_notes %></p>
        </div>
      <% end %>

      <div class="flex items-center gap-2 text-detail border-t pt-4 divider">
        <% if @pairing.ai? %><span class="badge--ai"><%= t(".ai_generated") %></span><% end %>
        <span><%= @pairing.public? ? t(".public") : t(".private") %></span>
        <span>&middot; <%= time_ago_in_words(@pairing.created_at) %> ago</span>
      </div>
    </div>
  </div>
</div>
