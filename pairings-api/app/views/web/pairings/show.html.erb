<div class="space-y-6">
  <div class="flex items-center justify-between">
    <%= link_to web_pairings_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <%= t(".back") %>
    <% end %>
    <%= button_to t(".delete"), web_pairing_path(@pairing), method: :delete,
        data: { turbo_confirm: t(".delete_confirm") },
        class: "rounded-lg border border-red-200 px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50" %>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm">
    <div class="flex">
      <% [@pairing.item1, @pairing.item2].each do |item| %>
        <%= link_to web_item_path(item), class: "w-1/2 group" do %>
          <div class="aspect-square bg-gray-100 overflow-hidden">
            <% if item.image.attached? %>
              <%= image_tag item.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: item.name %>
            <% end %>
          </div>
          <div class="p-3 text-center">
            <p class="text-sm font-semibold text-gray-900 truncate"><%= item.name %></p>
            <span class="text-xs text-gray-500"><%= Item::CATEGORIES[item.category] %></span>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="p-4 sm:p-6 space-y-4 border-t border-gray-100">
      <% if @pairing.strength %>
        <div class="flex items-center gap-3">
          <span class="text-sm font-medium text-gray-700"><%= t(".strength") %></span>
          <div class="flex gap-1">
            <% 5.times do |i| %>
              <div class="w-8 h-2 rounded-full <%= i < @pairing.strength ? 'bg-amber-400' : 'bg-gray-200' %>"></div>
            <% end %>
          </div>
          <span class="text-sm text-gray-500"><%= @pairing.strength %>/5</span>
        </div>
      <% end %>

      <% if @pairing.confidence_score %>
        <div class="flex items-center gap-3">
          <span class="text-sm font-medium text-gray-700"><%= t(".confidence") %></span>
          <span class="text-sm text-gray-500"><%= number_to_percentage(@pairing.confidence_score * 100, precision: 0) %></span>
        </div>
      <% end %>

      <% if @pairing.ai_reasoning.present? %>
        <div>
          <h3 class="text-sm font-medium text-gray-700 mb-1"><%= t(".ai_reasoning") %></h3>
          <p class="text-sm text-gray-600 leading-relaxed"><%= @pairing.ai_reasoning %></p>
        </div>
      <% end %>

      <% if @pairing.pairing_notes.present? %>
        <div>
          <h3 class="text-sm font-medium text-gray-700 mb-1"><%= t(".notes") %></h3>
          <p class="text-sm text-gray-600 leading-relaxed"><%= @pairing.pairing_notes %></p>
        </div>
      <% end %>

      <div class="flex items-center gap-2 text-xs text-gray-400 border-t border-gray-100 pt-4">
        <% if @pairing.ai? %><span class="text-indigo-500"><%= t(".ai_generated") %></span><% end %>
        <span><%= @pairing.public? ? t(".public") : t(".private") %></span>
        <span>&middot; <%= time_ago_in_words(@pairing.created_at) %> ago</span>
      </div>
    </div>
  </div>
</div>
