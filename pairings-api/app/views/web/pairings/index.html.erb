<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="heading-page"><%= t(".title") %></h1>
    <%= link_to t(".new_pairing"), new_web_pairing_path, class: "btn btn--primary" %>
  </div>

  <% if @pairings.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% @pairings.each do |pairing| %>
        <%= render "web/shared/pairing_card", pairing: pairing %>
      <% end %>
    </div>

    <%= render "web/shared/pagination" %>
  <% else %>
    <div class="empty-state">
      <p><%= t(".no_pairings") %></p>
      <%= link_to t(".create_first"), new_web_pairing_path, class: "mt-2 inline-block text-link" %>
    </div>
  <% end %>
</div>
