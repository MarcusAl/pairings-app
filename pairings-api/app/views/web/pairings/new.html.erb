<div class="space-y-6">
  <h1 class="heading-page"><%= t(".title") %></h1>
  <p class="text-body"><%= t(".subtitle") %></p>

  <% if @items.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <% @items.each do |item| %>
        <div class="relative">
          <%= button_to web_pairings_path, params: { item1_id: item.id }, class: "w-full text-left group" do %>
            <div class="card card--hover cursor-pointer" style="border-color: var(--border-card); transition: border-color 0.2s;">
              <div class="card__image">
                <% if item.image.attached? %>
                  <%= image_tag item.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: item.name %>
                <% end %>
              </div>
              <div class="p-3">
                <p class="text-sm font-semibold truncate" style="color: var(--text-primary);"><%= item.name %></p>
                <p class="text-detail"><%= Item::CATEGORIES[item.category] %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p><%= t(".no_items") %></p>
      <%= link_to t(".add_item"), new_web_item_path, class: "mt-2 inline-block text-link" %>
    </div>
  <% end %>
</div>
