<div class="space-y-6">
  <h1 class="heading-page"><%= t(".title") %></h1>
  <p class="text-body"><%= t(".subtitle") %></p>

  <% if @items.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <% @items.each do |item| %>
        <%= button_to web_pairings_path, params: { item1_id: item.id }, class: "w-full text-left" do %>
          <div class="card card--hover cursor-pointer">
            <div class="card__image">
              <% if item.image.attached? %>
                <%= image_tag item.image, class: "w-full h-full object-cover", alt: item.name %>
              <% end %>
              <span class="badge--overlay"><%= Item::CATEGORIES[item.category] %></span>
            </div>
            <div class="card__body">
              <p class="card__title"><%= item.name %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <p><%= t(".no_items") %></p>
      <%= link_to t(".add_item"), new_web_item_path, class: "mt-2 inline-block text-link" %>
    </div>
  <% end %>
</div>
