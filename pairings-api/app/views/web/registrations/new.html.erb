<div class="flex min-h-[80vh] items-center justify-center relative">
  <div class="wine-ring"></div>
  <div class="w-full max-w-sm space-y-6 relative z-10">
    <div class="text-center">
      <h1 class="heading-auth"><%= t(".title") %></h1>
      <p class="mt-1 text-body"><%= t(".subtitle") %></p>
    </div>

    <%= form_with model: @user, url: web_signup_path, class: "space-y-4",
        data: { controller: "form-validation", action: "input->form-validation#validate change->form-validation#validate" } do |f| %>
      <% if @user.errors.any? %>
        <div class="form-error">
          <ul class="list-disc pl-4 space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <div>
        <%= f.label :password, t(".password_label"), class: "form-label" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password", minlength: 12, class: "form-input" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "form-label" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", minlength: 12, class: "form-input" %>
      </div>

      <%= f.submit t(".create_account"), class: "btn btn--primary btn--full transition-opacity", data: { form_validation_target: "submit" } %>
    <% end %>

    <div class="relative">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t divider"></div></div>
      <div class="relative flex justify-center text-sm"><span class="divider-text px-2"><%= t(".or") %></span></div>
    </div>

    <%= button_to t(".continue_with_auth0"), "/auth/auth0", method: :post, data: { turbo: false },
        class: "btn btn--secondary btn--full" %>

    <p class="text-center text-body">
      <%= t(".have_account_html", link: link_to(t(".sign_in"), web_login_path, class: "text-link")) %>
    </p>
  </div>
</div>
