<div class="flex min-h-[80vh] items-center justify-center">
  <div class="w-full max-w-sm space-y-6">
    <div class="text-center">
      <h1 class="text-2xl font-bold">Create account</h1>
      <p class="mt-1 text-sm text-gray-500">Start pairing your favourite foods and drinks</p>
    </div>

    <%= form_with model: @user, url: web_signup_path, class: "space-y-4" do |f| %>
      <% if @user.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
          <ul class="list-disc pl-4 space-y-1">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email, required: true, autofocus: true, autocomplete: "email",
            class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :password, "Password (12 characters minimum)", class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password", minlength: 12,
            class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", minlength: 12,
            class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <%= f.submit "Create account", class: "w-full rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 cursor-pointer" %>
    <% end %>

    <div class="relative">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
      <div class="relative flex justify-center text-sm"><span class="bg-gray-50 px-2 text-gray-500">or</span></div>
    </div>

    <%= button_to "Continue with Auth0", "/auth/auth0", method: :post, data: { turbo: false },
        class: "w-full rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer" %>

    <p class="text-center text-sm text-gray-500">
      Already have an account? <%= link_to "Sign in", web_login_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
    </p>
  </div>
</div>
