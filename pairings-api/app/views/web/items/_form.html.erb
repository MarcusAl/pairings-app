<%= form_with model: item, url: url, class: "space-y-4",
    data: { controller: "form-validation", action: "input->form-validation#validate change->form-validation#validate" } do |f| %>
  <% if item.errors.any? %>
    <div class="form-error">
      <ul class="list-disc pl-4 space-y-1">
        <% item.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div data-controller="image-preview">
    <%= f.label :image, class: "form-label" %>
    <%= f.file_field :image, accept: "image/png,image/jpeg", class: "form-file",
        data: { image_preview_target: "input", action: "change->image-preview#preview" } %>
    <% if item.image.attached? && item.persisted? %>
      <div class="mt-2 w-24 h-24 rounded overflow-hidden image-bg">
        <%= image_tag item.image, class: "w-full h-full object-cover", alt: t("web.items.form.current_image"),
            data: { image_preview_target: "preview" } %>
      </div>
    <% else %>
      <div class="mt-2 w-24 h-24 rounded overflow-hidden image-bg hidden" data-image-preview-target="container">
        <img class="w-full h-full object-cover" data-image-preview-target="preview" alt="">
      </div>
    <% end %>
  </div>

  <div>
    <%= f.label :name, class: "form-label form-label--required" %>
    <%= f.text_field :name, required: true, placeholder: " ", class: "form-input" %>
  </div>

  <div>
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, rows: 3, class: "form-input" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :category, class: "form-label form-label--required" %>
      <%= f.select :category, options_for_select(Item::CATEGORIES.map { |k, v| [v, k] }, item.category),
          { prompt: t("web.items.form.select_category") },
          { required: true, class: "form-select" } %>
    </div>

    <div>
      <%= f.label :price_range, class: "form-label form-label--required" %>
      <%= f.select :price_range, options_for_select(Item::PRICE_RANGES.map { |k, v| ["#{k} — #{v}", k] }, item.price_range),
          { prompt: t("web.items.form.select_range") },
          { required: true, class: "form-select" } %>
    </div>
  </div>

  <div>
    <%= f.label :subcategory, class: "form-label" %>
    <%= f.text_field :subcategory, placeholder: t("web.items.form.subcategory_placeholder"), class: "form-input" %>
  </div>

  <fieldset>
    <legend class="form-label mb-2"><%= t("web.items.form.flavor_profiles") %></legend>
    <div class="flex flex-wrap gap-2">
      <% %w[sweet salty sour bitter umami spicy smoky herbal floral fruity nutty earthy rich tangy].each do |flavor| %>
        <label class="flavor-chip">
          <%= check_box_tag "item[flavor_profiles][]", flavor, item.flavor_profiles.include?(flavor), class: "sr-only" %>
          <%= flavor %>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div>
    <%= f.label :primary_flavor_profile, class: "form-label form-label--required" %>
    <%= f.text_field :primary_flavor_profile, required: true, placeholder: t("web.items.form.primary_flavor_placeholder"), class: "form-input" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :public, class: "form-checkbox" %>
    <%= f.label :public, t("web.items.form.make_public"), class: "text-sm", style: "color: var(--text-secondary);" %>
  </div>

  <%= f.submit class: "btn btn--primary btn--full transition-opacity", data: { form_validation_target: "submit" } %>
<% end %>
