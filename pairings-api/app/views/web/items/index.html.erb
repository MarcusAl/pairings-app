<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-bold text-gray-900"><%= t(".title") %></h1>
    <%= link_to t(".add_item"), new_web_item_path, class: "rounded-lg bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700" %>
  </div>

  <%= form_with url: web_items_path, method: :get, class: "flex gap-2", data: { turbo_frame: "_top" } do |f| %>
    <%= f.search_field :search, value: params[:search], placeholder: t(".search_placeholder"),
        class: "flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-amber-500 focus:ring-amber-500" %>
    <%= f.select :by_category, options_for_select(Item::CATEGORIES.map { |k, v| [v, k] }, params[:by_category]),
        { include_blank: t(".all_categories") },
        class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-amber-500 focus:ring-amber-500" %>
    <%= f.submit t(".filter"), class: "rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200 cursor-pointer" %>
  <% end %>

  <% if @items.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <% @items.each do |item| %>
        <%= render "web/shared/item_card", item: item %>
      <% end %>
    </div>

    <%= render "web/shared/pagination" %>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-500 text-sm"><%= t(".no_items") %></p>
      <%= link_to t(".add_first_item"), new_web_item_path, class: "mt-2 inline-block text-sm font-medium text-amber-600 hover:text-amber-700" %>
    </div>
  <% end %>
</div>
