<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="heading-page"><%= t(".title") %></h1>
    <%= link_to t(".add_item"), new_web_item_path, class: "btn btn--primary" %>
  </div>

  <div class="category-chips">
    <%= link_to t(".all_categories"), web_items_path, class: "shrink-0 badge #{params[:by_category].blank? ? 'badge--flavor-primary' : 'badge--flavor'} px-3 py-1" %>
    <% Item::CATEGORIES.each do |key, label| %>
      <%= link_to label, web_items_path(by_category: key), class: "shrink-0 badge #{params[:by_category] == key ? 'badge--flavor-primary' : 'badge--flavor'} px-3 py-1" %>
    <% end %>
  </div>

  <%= form_with url: web_items_path, method: :get, class: "grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-2", data: { turbo_frame: "_top" } do |f| %>
    <%= f.hidden_field :by_category, value: params[:by_category] %>
    <%= f.search_field :search, value: params[:search], placeholder: t(".search_placeholder"), class: "form-input mt-0" %>
    <%= f.submit t(".filter"), class: "btn btn--secondary cursor-pointer" %>
  <% end %>

  <% if @items.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <% @items.each do |item| %>
        <%= render "web/shared/item_card", item: item %>
      <% end %>
    </div>

    <%= render "web/shared/pagination" %>
  <% else %>
    <div class="empty-state">
      <svg class="w-16 h-16 mx-auto mb-3" fill="none" stroke="currentColor" style="color: var(--border-subtle);" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      <p><%= t(".no_items") %></p>
      <%= link_to t(".add_first_item"), new_web_item_path, class: "mt-3 inline-block btn btn--primary" %>
    </div>
  <% end %>
</div>
