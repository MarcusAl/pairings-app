<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="heading-page"><%= t(".title") %></h1>
    <%= link_to t(".add_item"), new_web_item_path, class: "btn btn--primary" %>
  </div>

  <%= form_with url: web_items_path, method: :get, class: "flex gap-2", data: { turbo_frame: "_top" } do |f| %>
    <%= f.search_field :search, value: params[:search], placeholder: t(".search_placeholder"), class: "form-input mt-0 flex-1" %>
    <%= f.select :by_category, options_for_select(Item::CATEGORIES.map { |k, v| [v, k] }, params[:by_category]),
        { include_blank: t(".all_categories") },
        class: "form-select mt-0" %>
    <%= f.submit t(".filter"), class: "btn btn--secondary cursor-pointer" %>
  <% end %>

  <% if @items.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <% @items.each do |item| %>
        <%= render "web/shared/item_card", item: item %>
      <% end %>
    </div>

    <%= render "web/shared/pagination" %>
  <% else %>
    <div class="empty-state">
      <p><%= t(".no_items") %></p>
      <%= link_to t(".add_first_item"), new_web_item_path, class: "mt-2 inline-block text-link" %>
    </div>
  <% end %>
</div>
