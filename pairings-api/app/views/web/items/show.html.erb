<div class="space-y-6">
  <div class="flex items-center justify-between">
    <%= link_to web_items_path, class: "back-link" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <%= t(".back") %>
    <% end %>
    <div class="flex gap-2">
      <%= link_to t(".edit"), edit_web_item_path(@item), class: "btn btn--secondary btn--sm" %>
      <%= button_to t(".delete"), web_item_path(@item), method: :delete,
          data: { turbo_confirm: t(".delete_confirm") },
          class: "btn btn--danger btn--sm" %>
    </div>
  </div>

  <div class="card">
    <% if @item.image.attached? %>
      <div class="aspect-[16/9] sm:aspect-[2/1] overflow-hidden" style="background: var(--border-card);">
        <%= image_tag @item.image, class: "w-full h-full object-cover", alt: @item.name %>
      </div>
    <% end %>

    <div class="p-4 sm:p-6 space-y-4">
      <div class="flex items-start justify-between gap-3">
        <h1 class="heading-page"><%= @item.name %></h1>
        <span class="shrink-0 badge badge--category px-3 py-1"><%= Item::CATEGORIES[@item.category] %></span>
      </div>

      <% if @item.description.present? %>
        <p class="text-body"><%= @item.description %></p>
      <% end %>

      <div class="flex flex-wrap gap-1.5">
        <% @item.flavor_profiles.each do |flavor| %>
          <span class="badge <%= flavor == @item.primary_flavor_profile ? 'badge--flavor-primary' : 'badge--flavor' %>">
            <%= flavor %>
          </span>
        <% end %>
      </div>

      <div class="flex items-center gap-4 text-body border-t pt-4 divider">
        <span><%= Item::PRICE_RANGES[@item.price_range] %></span>
        <% if @item.subcategory.present? %>
          <span>&middot; <%= @item.subcategory %></span>
        <% end %>
        <span>&middot; <%= @item.public? ? t(".public") : t(".private") %></span>
      </div>
    </div>
  </div>

  <% pairings = @item.pairings_as_item1.or(@item.pairings_as_item2).includes(:item1, :item2).limit(6) %>
  <% if pairings.any? %>
    <div class="space-y-3">
      <h2 class="heading-section"><%= t(".pairings") %></h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% pairings.each do |pairing| %>
          <%= render "web/shared/pairing_card", pairing: pairing %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
