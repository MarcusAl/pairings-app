<%= link_to (defined?(path) ? path : web_item_path(item)), class: "group block card card--hover" do %>
  <div class="card__image">
    <% if item.image.attached? %>
      <%= image_tag item.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: item.name %>
    <% else %>
      <div class="card__image-placeholder">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.41a2.25 2.25 0 013.182 0l2.909 2.91M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>
      </div>
    <% end %>
  </div>

  <div class="card__body">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-semibold text-sm leading-tight truncate" style="color: var(--text-primary);"><%= item.name %></h3>
      <span class="shrink-0 badge badge--category"><%= Item::CATEGORIES[item.category] %></span>
    </div>

    <div class="flex flex-wrap gap-1">
      <% item.flavor_profiles.first(3).each do |flavor| %>
        <span class="badge badge--flavor"><%= flavor %></span>
      <% end %>
    </div>

    <div class="flex items-center justify-between text-detail">
      <span><%= item.price_range %></span>
      <% if item.public? %>
        <span class="badge--public"><%= t("web.shared.item_card.public") %></span>
      <% end %>
    </div>
  </div>
<% end %>
