<div class="space-y-8" data-controller="animation">
  <div class="flex items-center justify-between">
    <h1 class="heading-page"><%= t(".title") %></h1>
    <div class="flex gap-2">
      <%= link_to t(".add_item"), new_web_item_path, class: "btn btn--primary" %>
      <%= link_to t(".new_pairing"), new_web_pairing_path, class: "btn btn--secondary" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div class="stat-card animate--fade-up" data-animation-target="item" data-animation-delay="0">
      <p class="text-2xl font-bold" style="color: var(--text-primary);"><%= current_user.items.count %></p>
      <p class="text-detail mt-1"><%= t(".items_count") %></p>
    </div>
    <div class="stat-card animate--fade-up" data-animation-target="item" data-animation-delay="100">
      <p class="text-2xl font-bold" style="color: var(--text-primary);"><%= current_user.pairings.count %></p>
      <p class="text-detail mt-1"><%= t(".pairings_count") %></p>
    </div>
  </div>

  <section class="space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="heading-section"><%= t(".recent_items") %></h2>
      <% if @recent_items.any? %>
        <%= link_to t(".view_all"), web_items_path, class: "text-link" %>
      <% end %>
    </div>
    <% if @recent_items.any? %>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        <% @recent_items.each do |item| %>
          <%= render "web/shared/item_card", item: item %>
        <% end %>
      </div>
    <% else %>
      <p class="text-body"><%= t(".no_items") %></p>
    <% end %>
  </section>

  <section class="space-y-3">
    <div class="flex items-center justify-between">
      <h2 class="heading-section"><%= t(".recent_pairings") %></h2>
      <% if @recent_pairings.any? %>
        <%= link_to t(".view_all"), web_pairings_path, class: "text-link" %>
      <% end %>
    </div>
    <% if @recent_pairings.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% @recent_pairings.each do |pairing| %>
          <%= render "web/shared/pairing_card", pairing: pairing %>
        <% end %>
      </div>
    <% else %>
      <p class="text-body"><%= t(".no_pairings") %></p>
    <% end %>
  </section>

  <section class="space-y-3">
    <h2 class="heading-section"><%= t(".inspiration") %></h2>
    <%= render "web/shared/carousel", images: @carousel_images %>
  </section>
</div>
