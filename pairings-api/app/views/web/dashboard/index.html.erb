<div class="space-y-8">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Dashboard</h1>
    <div class="flex gap-2">
      <%= link_to "Add Item", new_web_item_path, class: "inline-flex items-center rounded-lg bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
      <%= link_to "Start Pairing", new_web_pairing_path, class: "inline-flex items-center rounded-lg bg-white px-3 py-2 text-sm font-medium text-gray-700 border border-gray-300 hover:bg-gray-50" %>
    </div>
  </div>

  <section>
    <h2 class="text-lg font-semibold mb-3">Recent Items</h2>
    <% if @recent_items.any? %>
      <div class="grid gap-3">
        <% @recent_items.each do |item| %>
          <div class="flex items-center gap-3 rounded-lg bg-white p-3 border border-gray-200">
            <% if item.image.attached? %>
              <%= image_tag item.image, class: "w-12 h-12 rounded-lg object-cover", alt: item.name %>
            <% else %>
              <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-gray-400 text-xs">No img</div>
            <% end %>
            <div class="flex-1 min-w-0">
              <p class="font-medium truncate"><%= item.name %></p>
              <p class="text-sm text-gray-500"><%= item.category.capitalize %> &middot; <%= item.price_range %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No items yet. Add your first item to get started.</p>
    <% end %>
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-3">Recent Pairings</h2>
    <% if @recent_pairings.any? %>
      <div class="grid gap-3">
        <% @recent_pairings.each do |pairing| %>
          <div class="rounded-lg bg-white p-4 border border-gray-200">
            <div class="flex items-center gap-2 mb-2">
              <span class="font-medium"><%= pairing.item1.name %></span>
              <span class="text-gray-400">&amp;</span>
              <span class="font-medium"><%= pairing.item2.name %></span>
            </div>
            <% if pairing.ai_reasoning.present? %>
              <p class="text-sm text-gray-600 line-clamp-2"><%= pairing.ai_reasoning %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No pairings yet. Start pairing your items with AI.</p>
    <% end %>
  </section>
</div>
